# ─────────────────────────────────────────────────────────────────────────────
# ISKCON AI Calls — environment template
# Copy to `.env` and fill in. NEVER commit the real .env.
# All values below are PLACEHOLDERS — supply your own (client-owned) credentials.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3000

# Public HTTPS base URL of THIS backend. Plivo fetches the answer/status webhooks
# from here, so it must be reachable from the internet.
#   - local dev: an ngrok/cloudflared tunnel URL
#   - production: https://<your-app>.fly.dev
SERVER_URL=https://your-app.fly.dev

# Where the dashboard (Vercel) is hosted — used for CORS.
APP_URL=http://localhost:5173

# ─── Database (MongoDB Atlas) — you will provide a NEW url ────────────────────
DATABASE_URL=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/iskcon_alerts?retryWrites=true&w=majority&appName=IskconAlerts

# ─── Secrets — generate strong random values (openssl rand -hex 32) ───────────
JWT_SECRET=change-me-to-a-32char-plus-random-string
ENCRYPTION_KEY=change-me-to-a-32char-plus-random-string

# ─── Telephony: Plivo (client's own account) ─────────────────────────────────
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
# Default caller ID (the client's rented Plivo India number, E.164).
PLIVO_DEFAULT_NUMBER=+9180XXXXXXXX
# Verify Plivo webhook signatures. Keep true in production. true = fail closed.
PLIVO_SIGNATURE_INSECURE=false

# ─── Voice: Cartesia (TTS for the spoken alert) ──────────────────────────────
CARTESIA_API_KEY=
# Default Cartesia voice UUID + model for the alert announcement.
CARTESIA_DEFAULT_VOICE_ID=
CARTESIA_TTS_MODEL=sonic-2

# ─── LLM: Gemini (OPTIONAL — dashboard helper only, never used at call time) ──
# Used only to compose/translate the alert message text in the dashboard.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ─── First-run admin seed (used once by `npm run seed`) ──────────────────────
SEED_ORG_NAME=ISKCON Temple
SEED_ADMIN_EMAIL=admin@iskcon.local
SEED_ADMIN_PASSWORD=change-this-now

# ─── Frontend build-time (apps/web) ──────────────────────────────────────────
# In apps/web/.env set: VITE_API_URL=http://localhost:3000/api  (or your prod URL)
